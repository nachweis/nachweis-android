<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules (API 31+): govern cloud backup and device-to-device transfer.
    Every app-data domain is excluded from both channels. Wallet credentials, keys,
    databases, tokens, history, and logs must never be copied off-device or to another
    device. Applies in addition to android:allowBackup="false".
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="file" path="." />
        <exclude domain="external" path="." />
        <exclude domain="root" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="file" path="." />
        <exclude domain="external" path="." />
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>
