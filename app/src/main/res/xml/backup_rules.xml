<?xml version="1.0" encoding="utf-8"?>
<!--
    Auto Backup rules (API 26-30, fullBackupContent).
    Wallet data must never leave the device via auto-backup. android:allowBackup is
    already false; these explicit excludes are defense-in-depth so no subtree
    (databases, shared prefs, files, external, root) is ever captured.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="." />
    <exclude domain="database" path="." />
    <exclude domain="file" path="." />
    <exclude domain="external" path="." />
    <exclude domain="root" path="." />
</full-backup-content>
