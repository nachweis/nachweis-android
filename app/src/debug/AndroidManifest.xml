<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Debug builds allow cleartext to a local EUDIPLO; release builds do not. -->
    <application android:networkSecurityConfig="@xml/network_security_config">
        <!-- Debug-only screenshot/preview harness for the neo-brutal design system. Not present
             in release builds (debug source set). Exported so it can be launched over adb. -->
        <activity
            android:name="com.quellkern.nachweis.debug.PreviewGalleryActivity"
            android:exported="true"
            android:label="nachweis design gallery"
            android:theme="@style/Theme.Nachweis" />
    </application>
</manifest>
