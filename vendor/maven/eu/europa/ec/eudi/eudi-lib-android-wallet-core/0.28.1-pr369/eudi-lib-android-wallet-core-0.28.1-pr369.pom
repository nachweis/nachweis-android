<?xml version="1.0" encoding="UTF-8"?>
<project xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd" xmlns="http://maven.apache.org/POM/4.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <!-- Vendored patched build (nachweis): official wallet-core v0.28.1 + upstream PR #369. -->
  <!-- Gradle module metadata is intentionally omitted so consumers resolve via this POM, -->
  <!-- which carries the full transitive dependency set. See vendor/wallet-core-pr369/README.md. -->
  <modelVersion>4.0.0</modelVersion>
  <groupId>eu.europa.ec.eudi</groupId>
  <artifactId>eudi-lib-android-wallet-core</artifactId>
  <version>0.28.1-pr369</version>
  <packaging>aar</packaging>
  <name>eudi-lib-android-wallet-core</name>
  <description>EUDI Wallet Core library for Android</description>
  <url>https://github.com/eu-digital-identity-wallet/eudi-lib-android-wallet-core</url>
  <licenses>
    <license>
      <name>The Apache License, Version 2.0</name>
      <url>https://www.apache.org/licenses/LICENSE-2.0.txt</url>
    </license>
  </licenses>
  <developers>
    <developer>
      <url>https://github.com/eu-digital-identity-wallet</url>
    </developer>
  </developers>
  <scm>
    <connection>scm:git:git@github.com:eu-digital-identity-wallet/eudi-lib-android-wallet-core.git'</connection>
    <developerConnection>scm:git:ssh://github.com:eu-digital-identity-wallet/eudi-lib-android-wallet-core.git'</developerConnection>
    <url>https://github.com/eu-digital-identity-wallet/eudi-lib-android-wallet-core</url>
  </scm>
  <issueManagement>
    <system>github</system>
    <url>https://github.com/eu-digital-identity-wallet/eudi-lib-android-wallet-core/issues</url>
  </issueManagement>
  <ciManagement>
    <system>github</system>
    <url>https://github.com/eu-digital-identity-wallet/eudi-lib-android-wallet-core/actions</url>
  </ciManagement>
  <dependencies>
    <dependency>
      <groupId>eu.europa.ec.eudi</groupId>
      <artifactId>eudi-lib-android-wallet-document-manager</artifactId>
      <version>0.17.0</version>
      <scope>compile</scope>
    </dependency>
    <dependency>
      <groupId>eu.europa.ec.eudi</groupId>
      <artifactId>eudi-lib-android-iso18013-data-transfer</artifactId>
      <version>0.14.0</version>
      <scope>compile</scope>
    </dependency>
    <dependency>
      <groupId>eu.europa.ec.eudi</groupId>
      <artifactId>eudi-lib-jvm-openid4vci-kt</artifactId>
      <version>0.10.1</version>
      <scope>compile</scope>
    </dependency>
    <dependency>
      <groupId>org.multipaz</groupId>
      <artifactId>multipaz-android</artifactId>
      <version>0.99.0</version>
      <scope>compile</scope>
      <exclusions>
        <exclusion>
          <groupId>org.bouncycastle</groupId>
          <artifactId>*</artifactId>
        </exclusion>
        <exclusion>
          <groupId>io.ktor</groupId>
          <artifactId>*</artifactId>
        </exclusion>
      </exclusions>
    </dependency>
    <dependency>
      <groupId>eu.europa.ec.eudi</groupId>
      <artifactId>eudi-lib-kmp-statium-android</artifactId>
      <version>0.5.1</version>
      <scope>compile</scope>
    </dependency>
    <dependency>
      <groupId>org.jetbrains.kotlin</groupId>
      <artifactId>kotlin-stdlib</artifactId>
      <version>2.2.21</version>
      <scope>compile</scope>
    </dependency>
    <dependency>
      <groupId>org.jetbrains.kotlin</groupId>
      <artifactId>kotlin-parcelize-runtime</artifactId>
      <version>2.2.21</version>
      <scope>runtime</scope>
    </dependency>
    <dependency>
      <groupId>io.ktor</groupId>
      <artifactId>ktor-client-android</artifactId>
      <version>3.3.0</version>
      <scope>runtime</scope>
    </dependency>
    <dependency>
